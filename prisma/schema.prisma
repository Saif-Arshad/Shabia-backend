generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MODERATOR
  BUSINESS
}

enum Type {
  SERVICE
  NEWS
  EVENT
  JOB
}

model User {
  id          Int           @id @default(autoincrement())
  email       String        @unique
  password    String
  name        String?
  createdAt   DateTime      @default(now())
  latestOtp   String?
  location    String?
  isVerified  Boolean       @default(false)
  updatedAt   DateTime      @updatedAt
  Role        Role          @default(USER)
  Participant Participant[]
  Messages    Messages[]
  Posts       Posts[]
}

model Posts {
  id           Int           @id @default(autoincrement())
  type         Type          @default(SERVICE)
  title        String
  category     String
  description  String
  location1    String
  location2    String
  image        String
  eventDate    String?
  startTime    String?
  endTime      String?
  participants Participant[]
  jobType      String?
  contactEmail String?
  contactPhone String?
  company      String?
  salary       String?
  createdBy    Int
  user         User          @relation(fields: [createdBy], references: [id])
}

model Participant {
  id      Int    @id @default(autoincrement())
  userId  Int
  user    User   @relation(fields: [userId], references: [id])
  postId  Int
  Posts   Posts? @relation(fields: [postsId], references: [id])
  postsId Int?
}

model Messages {
  id        Int      @id @default(autoincrement())
  createdBy Int
  message   String
  user      User     @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
}
